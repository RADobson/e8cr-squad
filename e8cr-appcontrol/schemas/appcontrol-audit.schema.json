{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["appcontrol_policies_found", "policies", "severity", "escalation_reason"],
  "properties": {
    "appcontrol_policies_found": {"type": "integer", "minimum": 0},
    "severity": {"type": "string", "enum": ["P1", "P2", "P3"]},
    "escalation_reason": {"type": "string"},
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "isAssigned": {"type": "boolean"}
        }
      }
    }
  }
}
